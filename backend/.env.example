# Copy to .env and fill in your Supabase connection string.

# Server
PORT=4000
NODE_ENV=development

# CORS - comma-separated list of allowed origins for the frontend
CORS_ORIGIN=http://localhost:5173

# --- Database: Supabase (managed Postgres) ---
# Supabase project -> Settings -> Database -> Connection string.
#
# Use the DIRECT connection (host db.<ref>.supabase.co, port 5432) for running
# migrations and for this long-running Express server:
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
#
# Only use the Transaction Pooler (port 6543, host aws-0-<region>.pooler.supabase.com)
# if you deploy the API to a serverless/edge runtime that opens many short-lived
# connections. For a normal always-on Node server, prefer the direct 5432 URL above.

# Supabase requires SSL - keep this true.
PGSSL=true

# Rate limiting for the public submit endpoint
SUBMIT_RATE_WINDOW_MS=60000
SUBMIT_RATE_MAX=10
